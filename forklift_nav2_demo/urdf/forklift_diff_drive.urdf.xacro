<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="forklift_diff_drive">
  <xacro:arg name="gazebo_cmd_vel_topic" default="cmd_vel"/>

  <xacro:property name="wheel_radius" value="0.16"/>
  <xacro:property name="wheel_width" value="0.08"/>
  <xacro:property name="wheel_separation" value="0.76"/>
  <xacro:property name="base_z" value="0.22"/>

  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${base_z}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="28.0"/>
      <inertia ixx="1.20" ixy="0.0" ixz="0.0" iyy="3.40" iyz="0.0" izz="3.80"/>
    </inertial>
    <visual name="body_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1.685 1.16 0.28"/>
      </geometry>
      <material name="forklift_yellow">
        <color rgba="1.0 0.68 0.10 1.0"/>
      </material>
    </visual>
    <collision name="body_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1.685 1.16 0.28"/>
      </geometry>
    </collision>

    <visual name="counterweight_visual">
      <origin xyz="0.73 0 0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.24 1.06 0.34"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.08 0.09 0.10 1.0"/>
      </material>
    </visual>
    <collision name="counterweight_collision">
      <origin xyz="0.73 0 0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.24 1.06 0.34"/>
      </geometry>
    </collision>

    <visual name="mast_visual">
      <origin xyz="-0.843 0 0.30" rpy="0 0 0"/>
      <geometry>
        <box size="0.10 0.95 0.82"/>
      </geometry>
      <material name="mast_gray">
        <color rgba="0.18 0.20 0.22 1.0"/>
      </material>
    </visual>
    <collision name="mast_collision">
      <origin xyz="-0.843 0 0.30" rpy="0 0 0"/>
      <geometry>
        <box size="0.10 0.95 0.82"/>
      </geometry>
    </collision>

    <visual name="fork_left_visual">
      <origin xyz="-1.443 0.25 -0.13" rpy="0 0 0"/>
      <geometry>
        <box size="1.20 0.10 0.04"/>
      </geometry>
      <material name="fork_gray">
        <color rgba="0.32 0.34 0.35 1.0"/>
      </material>
    </visual>
    <collision name="fork_left_collision">
      <origin xyz="-1.443 0.25 -0.13" rpy="0 0 0"/>
      <geometry>
        <box size="1.20 0.10 0.04"/>
      </geometry>
    </collision>

    <visual name="fork_right_visual">
      <origin xyz="-1.443 -0.25 -0.13" rpy="0 0 0"/>
      <geometry>
        <box size="1.20 0.10 0.04"/>
      </geometry>
      <material name="fork_gray"/>
    </visual>
    <collision name="fork_right_collision">
      <origin xyz="-1.443 -0.25 -0.13" rpy="0 0 0"/>
      <geometry>
        <box size="1.20 0.10 0.04"/>
      </geometry>
    </collision>
  </link>

  <link name="left_wheel_link">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.018" ixy="0.0" ixz="0.0" iyy="0.032" iyz="0.0" izz="0.018"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="wheel_black">
        <color rgba="0.02 0.02 0.02 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="-0.34 ${wheel_separation / 2.0} -0.06" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="right_wheel_link">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.018" ixy="0.0" ixz="0.0" iyy="0.032" iyz="0.0" izz="0.018"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin xyz="-0.34 ${-wheel_separation / 2.0} -0.06" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="front_caster_link">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.4"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
    <visual>
      <geometry>
        <sphere radius="0.07"/>
      </geometry>
      <material name="caster_dark">
        <color rgba="0.05 0.05 0.05 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.07"/>
      </geometry>
    </collision>
  </link>

  <joint name="front_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_caster_link"/>
    <origin xyz="0.42 0 -0.15" rpy="0 0 0"/>
  </joint>

  <link name="base_scan">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.065" length="0.055"/>
      </geometry>
      <material name="laser_blue">
        <color rgba="0.05 0.24 0.80 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.065" length="0.055"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_scan_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_scan"/>
    <origin xyz="0.25 0 0.30" rpy="0 0 0"/>
  </joint>

  <gazebo reference="base_link">
    <material>Gazebo/Yellow</material>
  </gazebo>

  <gazebo reference="left_wheel_link">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <gazebo reference="right_wheel_link">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <gazebo reference="front_caster_link">
    <material>Gazebo/Black</material>
    <mu1>0.01</mu1>
    <mu2>0.01</mu2>
  </gazebo>

  <gazebo reference="base_scan">
    <sensor name="forklift_laser" type="ray">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>8.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="forklift_laserscan" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>base_scan</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo>
    <plugin name="forklift_diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <remapping>cmd_vel:=$(arg gazebo_cmd_vel_topic)</remapping>
      </ros>
      <update_rate>50</update_rate>
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>${wheel_separation}</wheel_separation>
      <wheel_diameter>${2.0 * wheel_radius}</wheel_diameter>
      <max_wheel_torque>80</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>

    <plugin name="forklift_joint_state" filename="libgazebo_ros_joint_state_publisher.so">
      <ros>
        <remapping>~/out:=joint_states</remapping>
      </ros>
      <update_rate>50</update_rate>
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
    </plugin>
  </gazebo>
</robot>
